<Window x:Class="DijkstraAnimation.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DijkstraAnimation.App"
        Title="Dijkstra's Algorithm — GPU Animated"
        Width="1400" Height="900"
        Background="#181825"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="#1E1E2E" Padding="14,10"
                BorderBrush="#2A2A4A" BorderThickness="0,0,0,1">
            <WrapPanel VerticalAlignment="Center">
                <TextBlock Text="Nodes:" Foreground="#CCD" VerticalAlignment="Center"
                           Margin="0,0,6,0" FontSize="13"/>
                <Slider x:Name="NodeCountSlider" Minimum="10" Maximum="300" Value="50"
                        Width="160" VerticalAlignment="Center"
                        IsSnapToTickEnabled="True" TickFrequency="5"/>
                <TextBlock x:Name="NodeCountText" Text="50" Foreground="White" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="6,0,24,0" Width="30" FontSize="13"/>

                <TextBlock Text="Speed:" Foreground="#CCD" VerticalAlignment="Center"
                           Margin="0,0,6,0" FontSize="13"/>
                <Slider x:Name="SpeedSlider" Minimum="1" Maximum="200" Value="20"
                        Width="160" VerticalAlignment="Center"/>
                <TextBlock x:Name="SpeedText" Text="20" Foreground="White" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="6,0,24,0" Width="30" FontSize="13"/>

                <Button x:Name="StartButton" Content="▶  Generate &amp; Run" Padding="14,7"
                        FontSize="13" FontWeight="SemiBold"
                        Background="#4A90D9" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button x:Name="ResetButton" Content="⟳  Reset" Padding="14,7" Margin="10,0,0,0"
                        FontSize="13"
                        Background="#4A4A6A" Foreground="White" BorderThickness="0" Cursor="Hand"/>

                <TextBlock x:Name="StatusText" Text="Click Generate &amp; Run to begin"
                           Foreground="#888" VerticalAlignment="Center" Margin="24,0,0,0" FontSize="13"/>
            </WrapPanel>
        </Border>

        <!-- Legend -->
        <Border DockPanel.Dock="Bottom" Background="#1E1E2E" Padding="14,7"
                BorderBrush="#2A2A4A" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="11" Height="11" Fill="#00CC66" Margin="0,0,4,0"/>
                <TextBlock Text="Start" Foreground="#AAA" Margin="0,0,16,0"
                           VerticalAlignment="Center" FontSize="12"/>
                <Ellipse Width="11" Height="11" Fill="#FF4444" Margin="0,0,4,0"/>
                <TextBlock Text="End" Foreground="#AAA" Margin="0,0,16,0"
                           VerticalAlignment="Center" FontSize="12"/>
                <Ellipse Width="11" Height="11" Fill="#FFA500" Margin="0,0,4,0"/>
                <TextBlock Text="Frontier" Foreground="#AAA" Margin="0,0,16,0"
                           VerticalAlignment="Center" FontSize="12"/>
                <Ellipse Width="11" Height="11" Fill="White" Margin="0,0,4,0"/>
                <TextBlock Text="Current" Foreground="#AAA" Margin="0,0,16,0"
                           VerticalAlignment="Center" FontSize="12"/>
                <Ellipse Width="11" Height="11" Fill="#4A90D9" Margin="0,0,4,0"/>
                <TextBlock Text="Visited" Foreground="#AAA" Margin="0,0,16,0"
                           VerticalAlignment="Center" FontSize="12"/>
                <Ellipse Width="11" Height="11" Fill="#FFD700" Margin="0,0,4,0"/>
                <TextBlock Text="Shortest Path" Foreground="#AAA"
                           VerticalAlignment="Center" FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- GPU-rendered graph canvas -->
        <Border ClipToBounds="True" Background="#181825">
            <local:GraphCanvas x:Name="Canvas"/>
        </Border>
    </DockPanel>
</Window>
